HERMES_IMAGE=nousresearch/hermes-agent:latest
HERMES_CONTAINER_NAME=gobe-hermes

HERMES_BIND_HOST=127.0.0.1
HERMES_GATEWAY_PORT=8642
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD=1

HERMES_VOLUME_NAME=gobe_hermes_data

# Use `HERMES_UID=$(id -u) HERMES_GID=$(id -g) docker compose up -d`
# on macOS/Linux so Hermes runs with your host UID/GID inside the container.
HERMES_UID=10000
HERMES_GID=10000

# Optional provider and gateway credentials.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
TELEGRAM_BOT_TOKEN=
